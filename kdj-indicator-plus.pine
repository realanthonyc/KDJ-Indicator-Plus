//@version=6
// -----------------------------------------------------------------------------
//  KDJ Indicator Plus
//  On GitHub: https://github.com/realanthonyc/KDJ-Indicator-Plus
//  v1.1.6
// -----------------------------------------------------------------------------
indicator("KDJ Indicator Plus", shorttitle="KDJ", overlay=false, precision=2)

// Inputs
period = input.int(9, "Period", minval=1)
signal = input.int(3, "Signal", minval=1)

// Core calc
hi  = ta.highest(high, period)
lo  = ta.lowest(low,  period)
rng = hi - lo
rsv = rng == 0 ? 0.0 : (close - lo) / rng * 100.0

// Wilder smoothing
K = ta.rma(rsv, signal)
D = ta.rma(K,   signal)
J = 3.0 * K - 2.0 * D

// Background
bgcolor(J > D ? color.new(color.green, 92) : color.new(color.red, 100))

// Guides
hline(100, "100", color=color.new(color.red, 45), linestyle=hline.style_dotted)
hline(80, "Upper", color=color.new(color.aqua, 50), linestyle=hline.style_dashed)
hline(50, "Mid", color=color.new(color.aqua, 40), linestyle=hline.style_dashed)
hline(20, "Lower", color=color.new(color.aqua, 50), linestyle=hline.style_dashed)
hline(0, "0", color=color.new(color.green, 25), linestyle=hline.style_dotted)

// Plotting
plot(K, "K", color=color.new(color.orange, 30), linewidth=1)
plot(D, "D", color=color.new(color.aqua, 50), linewidth=2)
plot(J, "J", color=color.new(color.fuchsia, 30), linewidth=1)
